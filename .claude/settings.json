{
  "permissions": {
    "allowedTools": [
      "Edit",
      "Write",
      "Bash(npm run *)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(npm test*)",
      "Bash(npm exec *)",
      "Bash(npm list *)",
      "Bash(npm info *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(tsc *)",
      "Bash(vitest *)",
      "Bash(playwright *)",
      "Bash(prettier *)",
      "Bash(eslint *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git stash*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git rev-parse*)",
      "Bash(git worktree*)",
      "Bash(git remote*)",
      "Bash(git tag*)",
      "Bash(git cherry-pick*)",
      "Bash(git clean*)",
      "Bash(git config *)",
      "Bash(git ls-files*)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(mkdir *)",
      "Bash(cat *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(touch *)",
      "Bash(chmod +x *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(tee *)",
      "Bash(xargs *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(pwd)",
      "Bash(date *)",
      "Bash(date)",
      "Bash(env *)",
      "Bash(printenv*)",
      "Bash(which *)",
      "Bash(command *)",
      "Bash(type *)",
      "Bash(cd *)",
      "Bash(realpath *)",
      "Bash(dirname *)",
      "Bash(basename *)",
      "Bash(diff *)",
      "Bash(patch *)",
      "Bash(curl *)",
      "Bash(jq *)",
      "Bash(supabase *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hook": ".claude/hooks/protect-generated-files.sh",
        "description": "Prevent editing auto-generated files (database.ts, lock files)"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hook": ".claude/hooks/post-write-lint.sh",
        "description": "Auto-lint TypeScript files after creation or edit"
      }
    ]
  }
}
